    if [ -z "{{id}}" ]; then
      just bin kafka-configs.sh --bootstrap-server localhost:9092 --describe --entity-type brokers --all
    else
      just bin kafka-configs.sh --bootstrap-server localhost:9092 --describe --entity-type brokers --entity-name {{id}} --all
    fi

